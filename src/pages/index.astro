---
import Layout from "../layouts/Layout.astro";
import HeroHome from "../components/HeroHome.astro";
import TextMarquee from "../components/TextMarquee.astro";
import GalleryText from "../components/GalleryText.astro";
import ImageMarquee from "../components/ImageMarquee.astro";
import Faqs from "../components/Faqs.astro";
import StepsTimeline from "../components/StepsTimeline.astro";
import Plans from "../components/Plans.astro";
import Statements from "../components/Statements.astro";
import Introducing from "../components/Introducing.astro";
import GL from "../components/GL.astro";
import GLPlaces from "../components/GlPlaces.astro";
import GLProjectCore from "../components/GL_project_core.astro";
import logo1 from "../assets/logoipsum-344.svg";
import logo2 from "../assets/logoipsum-350.svg";
import logo3 from "../assets/logoipsum-345.svg";
import logo4 from "../assets/logoipsum-385.svg";
import logo5 from "../assets/logoipsum-375.svg";
import logo6 from "../assets/logoipsum-378.svg";
import logo7 from "../assets/logoipsum-346.svg";
import logo8 from "../assets/logoipsum-331.svg";
---

<Layout title="Home">
  <HeroHome
    title="Your Projects. One Home."
    subtitle="A desktop app that turns your local coding projects into a clean, organized library. Browse projects, track time, view README and git activity, favorite the ones that matter, and jump back into coding instantly."
    cta={{
      title: "Download",
      url: "/",
    }}
  />

  <Introducing
    title="A better way to manage your coding projects"
    text="This desktop app gives developers one place to organize, revisit, and track their local projects. Instead of digging through folders, editor history, or old repositories, you get a clean library where every project feels visible, structured, and easy to return to."
  />

  <StepsTimeline
    title="How it works"
    items={[
      {
        title: "Download and install the app",
        text: "Install the desktop app on your PC and launch it. Windows may show a security prompt during installation since the app is independently distributed, but once installed, you're ready to start building your library.",
      },
      {
        title: "Scan your projects",
        text: "Run an initial scan to detect your local projects and automatically populate your library. Your projects are gathered into one place so you can browse them without digging through folders.",
      },
      {
        title: "Organize and jump back in",
        text: "Favorite important projects, group them your way, view README and git activity, track time spent, and open any project instantly in your preferred code editor.",
      },
    ]}
  />
  <GalleryText
    title="A cleaner way to manage your coding projects"
    text="Keep your local projects in one organized desktop library. Browse them from a sidebar, reopen work instantly, track time spent, and explore README content and git activity from one focused view."
    cta={{
      title: "Download the App",
      url: "/",
    }}
    images={[
      {
        alt: "Project library sidebar with favorite coding projects",
        src: "/image1-1.png",
        width: 376,
        height: 751,
      },
      {
        alt: "Selected project view showing README, tracked time, and project details",
        src: "/image2.png",
        width: 1020,
        height: 814,
      },
      {
        alt: "Git activity view with commits, changed files, and diffs",
        src: "/image3.png",
        width: 1020,
        height: 814,
      },
    ]}
    marqueeTexts={[
      "Local Project Library",
      "Tracked Time",
      "README and Git Activity",
      "Launch in One Click",
    ]}
  />

  <Statements
    items={[
      {
        title: "All your projects, one place",
        text: "Bring scattered local projects into a single library that is easier to browse, manage, and return to.",
      },
      {
        title: "See progress, not just files",
        text: "Track time spent, read project documentation, and explore git activity from one clear project view.",
      },
      {
        title: "Jump back into work faster",
        text: "Favorite important projects, group them your way, and launch directly into your preferred code editor.",
      },
    ]}
  />

  <TextMarquee
    class="marquee"
    texts={[
      "Local Project Library",
      "Tracked Time",
      "README and Git Activity",
      "Launch in One Click",
    ]}
  />

  <Faqs
    title="Frequently Asked Questions"
    mobileTitle="FAQs"
    subtitle="Quick answers to the most common questions."
    items={[
      {
        question: "What is this software?",
        answer:
          "It’s a desktop app that turns your coding projects into a personal library. You can browse local projects, favorite and group them, track time spent, read project README files, inspect git activity, and launch projects directly in your preferred code editor.",
      },
      {
        question: "Who is it for?",
        answer:
          "It’s made for developers, hobby developers, students, and anyone with multiple coding projects spread across folders, repositories, or editor history who wants a cleaner way to manage them.",
      },
      {
        question: "Is it really free?",
        answer:
          "Yes. The app is free to use. There are no subscriptions or paid plans. If you enjoy it and want to support development, donations are completely optional.",
      },
      {
        question: "Does it upload my code or project data?",
        answer:
          "No. The app works locally on your computer and does not upload your projects or files anywhere. Everything stays offline, except when you choose to interact with GitHub features such as browsing or cloning repositories.",
      },
      {
        question: "Do I need Git to use it?",
        answer:
          "No. You can use the app without Git to organize, manage, and launch your projects. Git-enabled projects simply show extra details like commits, changed files, and diffs.",
      },
      {
        question: "Why might Windows show a warning during installation?",
        answer:
          "Because the app is independently distributed, Windows may show a security prompt during installation. This is common with newer desktop apps that are not yet widely recognized.",
      },
      {
        question: "Can I use it with GitHub repositories?",
        answer:
          "Yes. You can browse public repositories and your own private repositories through GitHub, then clone them directly to your local machine. Outside of those requests, the app stays fully local.",
      },
      {
        question: "Can I choose which editor opens my project?",
        answer:
          "Yes. The app lets you launch projects in your preferred code editor so you can jump back into work quickly.",
      },
    ]}
  />

  <!-- <GL /> -->
  <GLPlaces />
  <GLProjectCore />
</Layout>

<style>
  .marquee {
    padding: 2rem 0;
    z-index: 9;
  }
</style>
